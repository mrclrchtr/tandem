amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Builtins.pkl"

// Exclude skill trees from hook file selection. This prevents hk from stashing/restoring
// when commits only touch skills (and avoids edge-cases with symlink-to-directory entries
// like `.claude/skills/*`).
exclude =
  List(
    ".agents/**",
    ".claude/**",
    "skills-lock.json",
    ".github/workflows/release.yml",
  )

local linters = new Mapping<String, Step | Group> {
  ["actionlint"] = Builtins.actionlint
  ["sync-version"] = new Step {
    workspace_indicator = "rust-toolchain.toml"
    check = "cargo xtask sync-version --check"
    fix = "cargo xtask sync-version"
  }
  ["cargo-fmt"] = (Builtins.cargo_fmt) {
    workspace_indicator = "rust-toolchain.toml"
    check = "cargo fmt --check --all"
    fix = "cargo fmt --all"
  }
  ["cargo-check"] = (Builtins.cargo_check) {
    workspace_indicator = "rust-toolchain.toml"
    check = "cargo check --workspace --all-targets --all-features --locked"
  }
  ["cargo-clippy"] = (Builtins.cargo_clippy) {
    workspace_indicator = "rust-toolchain.toml"
    check = "cargo clippy --workspace --all-targets --all-features --locked -- -D warnings"
    fix =
      "cargo clippy --workspace --all-targets --all-features --fix --allow-dirty --allow-staged --locked -- -D warnings"
  }
  ["newlines"] = Builtins.newlines
  ["trailing-whitespace"] = Builtins.trailing_whitespace
  ["pkl-format"] = Builtins.pkl_format
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }

  ["pre-push"] {
    fix = false
    steps = linters
  }

  ["check"] {
    fix = false
    steps = linters
  }

  ["fix"] {
    fix = true
    steps = linters
  }

  ["commit-msg"] {
    fix = false
    steps {
      ["commitlint"] = new Step {
        check = "commitlint --edit {{commit_msg_file}}"
      }
    }
  }
}
