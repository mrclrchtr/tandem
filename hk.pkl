amends "package://github.com/jdx/hk/releases/download/v1.41.0/hk@1.41.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.41.0/hk@1.41.0#/Builtins.pkl"

// Exclude skill trees from hook file selection. This prevents hk from stashing/restoring
// when commits only touch skills (and avoids edge-cases with symlink-to-directory entries
// like `.claude/skills/*`).
exclude =
  List(
    ".agents/**",
    ".claude/**",
    "skills-lock.json",
  )

local linters = new Mapping<String, Step | Group> {
  ["actionlint"] = Builtins.actionlint
  ["cargo-fmt"] = (Builtins.cargo_fmt) {
    workspace_indicator = "Cargo.toml"
    check = "cargo fmt --check --manifest-path {{workspace_indicator}} --all"
    fix = "cargo fmt --manifest-path {{workspace_indicator}} --all"
  }
  ["cargo-check"] = (Builtins.cargo_check) {
    workspace_indicator = "Cargo.toml"
    check =
      "cargo check --manifest-path {{workspace_indicator}} --workspace --all-targets --all-features --locked"
  }
  ["cargo-clippy"] = (Builtins.cargo_clippy) {
    workspace_indicator = "Cargo.toml"
    check =
      "cargo clippy --manifest-path {{workspace_indicator}} --workspace --all-targets --all-features --locked -- -D warnings"
    fix =
      "cargo clippy --manifest-path {{workspace_indicator}} --workspace --all-targets --all-features --fix --allow-dirty --allow-staged --locked -- -D warnings"
  }
  ["newlines"] = Builtins.newlines
  ["trailing-whitespace"] = Builtins.trailing_whitespace
  ["pkl-format"] = Builtins.pkl_format
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }

  ["pre-push"] {
    fix = false
    steps = linters
  }

  ["check"] {
    fix = false
    steps = linters
  }

  ["fix"] {
    fix = true
    steps = linters
  }
}
